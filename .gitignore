__pycache__/
*.py[cod]
.venv/
venv/
.env
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Claude Code personal/local settings (per-user permission allowlist, not project source)
.claude/settings.local.json
.ipynb_checkpoints/
.DS_Store

# Phase 4c: cached offline sweeps and exported paper figures are generated, not
# source (calibrated_markets.csv is a real calibration input and stays tracked).
sweeps/**/results.parquet
sweeps/**/manifest.json
/figures/
# transient sweep-run logs (joblib progress / RuntimeWarnings), not source
sweeps_*.log
sweeps_*.out
sweeps_*.err

# Calibration: never commit raw Dominick's data (large; >100MB files break GitHub).
# Only the derived data/calibrated_markets.csv, small data/reference/ decode tables,
# and the data/raw/dominicks/.gitkeep placeholder are tracked.
data/raw/dominicks/*
!data/raw/dominicks/.gitkeep
*.sd2
*.SD2
*.sas7bdat
